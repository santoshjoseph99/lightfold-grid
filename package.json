{
  "name": "starlight",
  "version": "1.0.0",
  "description": "Pseudo-Terminal Multi-Agent Workspace",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"Vite,Elec-TS,Elec-Run\" -c \"cyan,magenta,green\" \"vite\" \"tsc -w -p tsconfig.electron.json\" \"wait-on http://localhost:5173 && nodemon --delay 500ms --watch dist-electron --exec electron .\"",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.electron.json && vite build",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/*.test.ts",
    "test:ollama": "STARLIGHT_OLLAMA_TEST=1 node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/ollama-wheel.integration.test.ts",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "lucide-react": "^0.395.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.0.19",
    "strip-ansi": "^6.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.9",
    "nodemon": "^3.1.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  }
}
